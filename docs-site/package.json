{
  "name": "repository-docs-site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare-docs": "node ./scripts/assemble-docs.mjs",
    "lint": "markdownlint-cli2 --config ../.markdownlint.json ../README.md ../CHANGELOG.md \"../docs/**/*.md\" \"../new_repository_template/README.md\"",
    "check:external-links": "node ./scripts/check-external-links.mjs",
    "security:audit": "node ./scripts/audit-security.mjs",
    "build": "npm run prepare-docs && docusaurus build",
    "verify:build": "node ./scripts/verify-build.mjs",
    "test:unit": "node --test ./tests/*.test.mjs",
    "test:browser": "playwright test",
    "check": "npm run lint && npm run test:unit && npm run check:external-links && npm run prepare-docs && docusaurus build --no-minify && npm run verify:build && npm run test:browser",
    "start": "npm run prepare-docs && docusaurus start --host 0.0.0.0",
    "serve": "docusaurus serve --dir build --host 127.0.0.1 --port 3100 --no-open",
    "clear": "docusaurus clear"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@easyops-cn/docusaurus-search-local": "0.55.2",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@fontsource/ibm-plex-sans": "5.2.8",
    "prism-react-renderer": "2.4.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "overrides": {
    "js-yaml@^4": "4.2.0",
    "markdown-it": "14.2.0",
    "serialize-javascript": "7.0.5",
    "uuid": "11.1.1",
    "websocket-driver": "0.7.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "markdownlint-cli2": "0.18.1"
  },
  "license": "MIT"
}
